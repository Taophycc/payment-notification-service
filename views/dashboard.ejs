<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard — Payment Notification Service</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #f5f5f5;
      min-height: 100vh;
    }
    header {
      background: white;
      padding: 1rem 2rem;
      border-bottom: 1px solid #eee;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    header h1 { font-size: 1.2rem; }
    header a {
      font-size: 0.85rem;
      color: #666;
      text-decoration: none;
    }
    header a:hover { color: #000; }
    main { padding: 2rem; max-width: 1000px; margin: 0 auto; }
    h2 { font-size: 1.1rem; margin-bottom: 1rem; }
    table {
      width: 100%;
      background: white;
      border-radius: 8px;
      border-collapse: collapse;
      box-shadow: 0 2px 8px rgba(0,0,0,0.05);
      overflow: hidden;
    }
    th {
      text-align: left;
      padding: 0.8rem 1rem;
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #666;
      border-bottom: 1px solid #eee;
    }
    td {
      padding: 0.8rem 1rem;
      font-size: 0.9rem;
      border-bottom: 1px solid #f0f0f0;
    }
    tr:last-child td { border-bottom: none; }
    .badge {
      display: inline-block;
      padding: 0.2rem 0.6rem;
      border-radius: 20px;
      font-size: 0.75rem;
      font-weight: 500;
    }
    .badge.success { background: #e6f4ea; color: #1a7f37; }
    .badge.failed { background: #fce8e8; color: #c00; }
    .badge.pending { background: #fff3cd; color: #856404; }
    .empty {
      text-align: center;
      padding: 3rem;
      color: #999;
      font-size: 0.9rem;
    }
  </style>
</head>
<body>
  <header>
    <h1>Payment Notification Service</h1>
    <a href="/logout">Sign out</a>
  </header>
  <main>
    <h2>Recent Transactions</h2>
    <% if (transactions.length === 0) { %>
      <div class="empty">No transactions yet.</div>
    <% } else { %>
      <table>
        <thead>
          <tr>
            <th>Reference</th>
            <th>Email</th>
            <th>Amount</th>
            <th>Currency</th>
            <th>Status</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody>
          <% transactions.forEach(function(tx) { %>
            <tr>
              <td><%= tx.paystackReference %></td>
              <td><%= tx.customerEmail %></td>
              <td><%= (tx.amount / 100).toLocaleString() %></td>
              <td><%= tx.currency %></td>
              <td>
                <span class="badge <%= tx.status %>">
                  <%= tx.status %>
                </span>
              </td>
              <td><%= new Date(tx.createdAt).toLocaleDateString() %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </main>
</body>
</html>